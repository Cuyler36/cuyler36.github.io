---
layout: default
---
<article class="{% if page.feature-img %}feature-image{% endif %}">
  <header id="main" {% if page.feature-img %}style="background-image: url('{{ page.feature-img | relative_url }}')"{% endif %}>
    {% if page.hide_title %}
    {% else %}
      <h1 id="{{ page.title | default: '' | cgi_escape }}" class="title">{{ page.title }}</h1>
      {% if page.subtitle %}
        <h2 class="subtitle">{{ page.subtitle }}</h2>
      {% endif %}
    {% endif %}
  </header>
  <section class="post-content">
    {% if page.bootstrap %}
    <div class="bootstrap-iso">
    {% endif %}
    {{ content }}
    {% if page.bootstrap %}
    </div>
    {% endif %}
  </section>

  {% capture category_list %}{{ page.categories | join: "|" }}{% endcapture %}
  {% include default/category_list.liquid categories=category_list %}

  {% capture tag_list %}{{ page.tags | join: "|" }}{% endcapture %}
  {% include default/tags_list.liquid tags=tag_list %}
</article>
